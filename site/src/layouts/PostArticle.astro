---
import "@styles/global.css";
import "@styles/layouts/default.css";
import "github-markdown-css/github-markdown-light.css";

import { SiteDescription, SiteName } from "@lib/constants";
import type { LinkItem } from "@lib/types";
import { getRootRelativePath } from "@lib/utils";
import Breadcrumbs from "@components/common/Breadcrumbs.astro";
import Container from "@components/common/Container.astro";
import Footer from "@components/common/Footer.astro";
import GoTopButton from "@components/common/GoTopButton.astro";
import Header from "@components/common/Header.astro";
import PageProgressBar from "@components/common/PageProgressBar.astro";
import Hero from "@components/posts/Hero.astro";

const { title, description, image, date, category } = Astro.props.frontmatter;

const breadcrumbs: LinkItem[] = [
  {
    path: "/",
    label: "TOP",
  },
  {
    path: "/posts",
    label: "記事一覧",
  },
  {
    path: "",
    label: title || "",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={getRootRelativePath("/favicon.svg")}
    />
    <link rel="icon" href={getRootRelativePath("/favicon.ico")} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description || SiteDescription} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={description || SiteDescription} />
    <meta
      property="og:title"
      content={title ? `${title} | ${SiteName}` : SiteName}
    />
    <meta
      property="og:url"
      content={`${import.meta.env.DOMAIN}${import.meta.env.BASE}`}
    />
    <meta property="og:image" content={image} />
    <meta property="og:site_title" content={SiteName} />
    <title>{title ? `${title} | ${SiteName}` : SiteName}</title>
  </head>
  <body class="layouts-default">
    <PageProgressBar />
    <Header />
    <main class="layouts-default__main">
      <div class="layouts-default__breadcrumbs">
        <Container size="md">
          <Breadcrumbs items={breadcrumbs} />
        </Container>
      </div>
      <Container size="md">
        <div>
          <Hero title={title} date={date} category={category} image={image} />
          <div class="markdown-body">
            <slot />
          </div>
        </div>
        <div class="layouts-default__go-top-button" data-position="top">
          <GoTopButton />
        </div>
      </Container>
      <div class="layouts-default__breadcrumbs" data-position="bottom">
        <Container size="md">
          <Breadcrumbs items={breadcrumbs} />
        </Container>
      </div>
    </main>
    <Footer />
  </body>
  <script>
    import "@scripts/layouts/default";
  </script>
</html>
