---
import "@styles/global.css";

import { SiteDescription, SiteName } from "@lib/constants";
import { getRootRelativePath } from "@lib/utils";
import Footer from "@components/common/Footer.astro";
import GoTopButton from "@components/common/GoTopButton.astro";
import Header from "@components/common/Header.astro";
import PageProgressBar from "@components/common/PageProgressBar.astro";

interface Props {
  title?: string;
  description?: string;
}
const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={getRootRelativePath("/favicon.svg")}
    />
    <link rel="icon" href={getRootRelativePath("/favicon.ico")} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description || SiteDescription} />
    <title>{title ? `${title} | ${SiteName}` : SiteName}</title>
  </head>
  <body>
    <PageProgressBar />
    <Header />
    <main>
      <slot />
      <GoTopButton aria-disabled />
    </main>
    <Footer />
  </body>
</html>
