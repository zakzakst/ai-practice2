---
import { getRootRelativePath } from "@lib/utils";
import Layout from "@layouts/Default.astro";
import Accordion from "@components/common/Accordion.astro";
import Button from "@components/common/Button.astro";
import ButtonLink from "@components/common/ButtonLink.astro";
import Divider from "@components/common/Divider.astro";
import HeadingL from "@components/common/HeadingL.astro";
import HeadingM from "@components/common/HeadingM.astro";
import HeadingS from "@components/common/HeadingS.astro";
import Link from "@components/common/Link.astro";
import ParallaxImage from "@components/common/ParallaxImage.astro";
---

<Layout
  title="トップページ"
  description="トップページの概要"
  breadcrumbs={[
    {
      path: "/",
      label: "TOP",
    },
    {
      path: "/hoge",
      label: "HOGE",
    },
  ]}
>
  トップページ<Link class="aaa" href="/test" target="_blank">テキスト</Link
  >文中のリンク
  <br />
  <Link class="aaa" href="/test" target="_blank">test</Link>
  <Divider />
  <Divider color="black" />
  <Divider color="gray-light" />
  <Divider color="gray" />
  <p>{import.meta.env.DOMAIN}</p>
  <Button>button</Button>
  <Button aria-disabled>button</Button>
  <Button variant="outline">button</Button>
  <Button variant="outline" aria-disabled>button</Button>
  <Button variant="text">button</Button>
  <Button variant="text" aria-disabled>button</Button>
  <Button>button</Button>
  <Button size="lg">button</Button>
  <Button size="md">button</Button>
  <Button size="sm">button</Button>
  <Button size="xs">button</Button>

  <ButtonLink href="#" class:list={["hoge", "fuga"]}>button</ButtonLink>
  <ButtonLink aria-disabled>button</ButtonLink>
  <ButtonLink href="#" variant="outline">button</ButtonLink>
  <ButtonLink variant="outline" aria-disabled>button</ButtonLink>
  <ButtonLink href="#" variant="text">button</ButtonLink>
  <ButtonLink variant="text" aria-disabled>button</ButtonLink>
  <ButtonLink href="#">button</ButtonLink>
  <ButtonLink href="#" size="lg">button</ButtonLink>
  <ButtonLink href="#" size="md">button</ButtonLink>
  <ButtonLink href="#" size="sm">button</ButtonLink>
  <ButtonLink href="#" size="xs">button</ButtonLink>
  <Accordion>
    <Fragment slot="summary">summary</Fragment>
    <p>content</p>
  </Accordion>
  <Accordion>
    <Fragment slot="summary">アコーディオン</Fragment>
    <p>コンテンツ</p>
  </Accordion>
  <HeadingL tag="h2" class="custom-class">HeadingL</HeadingL>
  <HeadingL tag="h3" class="custom-class">HeadingL</HeadingL>
  <HeadingM tag="h2" class="custom-class">HeadingM</HeadingM>
  <HeadingM tag="h3" class="custom-class">HeadingM</HeadingM>
  <HeadingS tag="h2" class="custom-class">HeadingS</HeadingS>
  <HeadingS tag="h3" class="custom-class">HeadingS</HeadingS>
  <div>
    <ParallaxImage src={getRootRelativePath("/images/sample.webp")} alt="" />
  </div>
</Layout>
