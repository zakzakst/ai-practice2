---
import "@styles/common/container.css";

import type { HTMLAttributes } from "astro/types";

export type ContainerSize = "lg" | "md" | "sm";

interface Props extends HTMLAttributes<"div"> {
  size?: ContainerSize;
}
const { size = "lg", class: className, ...rest } = Astro.props;
---

<div class:list={["common-container", className]} data-size={size} {...rest}>
  <slot />
</div>
