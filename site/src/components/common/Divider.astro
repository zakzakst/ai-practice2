---
import "@styles/common/divider.css";

import type { HTMLAttributes } from "astro/types";

export type DividerColor = "black" | "gray" | "gray-light";

interface Props extends HTMLAttributes<"hr"> {
  color?: DividerColor;
}
const { color = "gray", class: className, ...rest } = Astro.props;
---

<hr class:list={["common-divider", className]} data-color={color} {...rest} />
